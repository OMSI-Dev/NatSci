# Environment Variables for SOS Control System

# This file demonstrates how to configure the system using environment variables.
# Copy this file to '.env' and customize for your environment.

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================

# SOS Server (NOAA Science on a Sphere)
SOS_IP=10.0.0.16
SOS_PORT=2468

# Raspberry Pi (Now Playing Display)
PI_IP=10.10.51.111
PI_PORT=4096
PI_ENABLED=false

# =============================================================================
# FILE PATHS
# =============================================================================

# Base network share (all other paths derived from this)
SOS_BASE_SHARE=\\sos2\AuxShare

# Or specify individual paths:
# SOS_CACHE_DIR=\\sos2\AuxShare\cache
# SOS_AUDIO_DIR=\\sos2\AuxShare\audio
# SOS_DATA_DIR=\\sos2\AuxShare\data

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable/disable system features
NOWPLAYING_ENABLED=false
AUDIO_ENABLED=true
SUBTITLES_ENABLED=true
HTTP_SERVER_ENABLED=true

# =============================================================================
# DEBUG FLAGS
# =============================================================================

# Debug mode (shows additional logging)
DEBUG_MODE=false
DEBUG_SHOW_BORDERS=false
DEBUG_VERBOSE_SSH=false
DEBUG_VERBOSE_MPV=false
